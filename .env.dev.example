# Umgebung: dev (dev.deine-domain)
# Diese Datei ist eine VORLAGE. Echte Werte werden in Coolify -> Environment Variables gesetzt.
# Die vollstaendige Liste aller Variablen steht in .env.local.example.

NEXT_PUBLIC_APP_ENV=dev
NEXT_PUBLIC_SITE_URL=https://dev.deine-domain

# Supabase (Dev-Instanz)
NEXT_PUBLIC_SUPABASE_URL=https://<dev-projekt>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# Hero API (Dev-Key, NICHT Prod)
HERO_API_KEY=
HERO_PROJECT_URL_TEMPLATE=https://hero.example/projects/{projectId}

# Cron
CRON_SECRET=

# Microsoft Graph (Dev-Mailbox oder deaktiviert)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_MAILBOX_EMAIL=

# Anthropic
ANTHROPIC_API_KEY=

# Notion (Dev-Workspace)
NOTION_API_KEY=
NOTION_TASKS_DATABASE_ID=
