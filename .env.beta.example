# Umgebung: beta (beta.deine-domain)
# Echte Werte werden in Coolify gesetzt. Vollstaendige Liste: .env.local.example.
# WICHTIG: beta nutzt bereits die Prod-Supabase-Instanz, damit echte Daten getestet werden.

NEXT_PUBLIC_APP_ENV=beta
NEXT_PUBLIC_SITE_URL=https://beta.deine-domain

# Supabase (Prod-Instanz, getrennt von dev/alpha)
NEXT_PUBLIC_SUPABASE_URL=https://<prod-projekt>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# Hero API (Prod)
HERO_API_KEY=
HERO_PROJECT_URL_TEMPLATE=https://hero.example/projects/{projectId}

CRON_SECRET=

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_MAILBOX_EMAIL=

ANTHROPIC_API_KEY=

NOTION_API_KEY=
NOTION_TASKS_DATABASE_ID=
