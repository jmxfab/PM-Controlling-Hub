# Umgebung: alpha (alpha.deine-domain)
# Echte Werte werden in Coolify gesetzt. Vollstaendige Liste: .env.local.example.

NEXT_PUBLIC_APP_ENV=alpha
NEXT_PUBLIC_SITE_URL=https://alpha.deine-domain

# Supabase (teilt sich typischerweise die Dev-Instanz mit dev, separate Row-Level-Policies moeglich)
NEXT_PUBLIC_SUPABASE_URL=https://<dev-projekt>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# Hero API
HERO_API_KEY=
HERO_PROJECT_URL_TEMPLATE=https://hero.example/projects/{projectId}

CRON_SECRET=

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_MAILBOX_EMAIL=

ANTHROPIC_API_KEY=

NOTION_API_KEY=
NOTION_TASKS_DATABASE_ID=
