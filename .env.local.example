# Supabase - Verbinde mit deiner lokalen Proxmox-Instanz
NEXT_PUBLIC_SUPABASE_URL=https://db.fabwagen.de
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...          # Supabase Dashboard → Settings → API → anon/public
SUPABASE_SERVICE_ROLE_KEY=eyJ...              # Supabase Dashboard → Settings → API → service_role

# Hero Software API
# Hole deinen API Key bei Hero: Einstellungen → Integrationen → API
HERO_API_KEY=dein-hero-api-key-hier

# Cron-Schutz (optional, für manuelle Trigger-Absicherung)
# Beliebigen sicheren Zufallswert eintragen
CRON_SECRET=ein-langer-zufaelliger-string
