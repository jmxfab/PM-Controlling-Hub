# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...          # Nur nötig, wenn künftig Browser-Reads/Auth dazukommen
SUPABASE_SECRET_KEY=sb_secret_...             # Bevorzugt für serverseitige Reads/Writes in Production
SUPABASE_SERVICE_ROLE_KEY=eyJ...              # Fallback für ältere Supabase-Projekte

# Hero Software API
# Hole deinen API Key bei Hero: Einstellungen → Integrationen → API
# Optional: du kannst den Key stattdessen auch direkt im Dashboard
# unter "Hero Read-only Status" eintragen (PROJ-2). Ein über die UI
# gespeicherter Wert hat Vorrang vor dieser Umgebungsvariable.
HERO_API_KEY=
HERO_PROJECT_URL_TEMPLATE=https://hero.example/projects/{projectId}

# Vercel Cron-Schutz (Authorization: Bearer <CRON_SECRET>)
# In Production sollte dieser Wert gesetzt sein.
CRON_SECRET=ein-langer-zufaelliger-string

# Optional: Sentry / Error Tracking
# SENTRY_DSN=https://...
# NEXT_PUBLIC_SENTRY_DSN=https://...

# ── E-Mail Klassifizierung (PROJ-2) ──────────────────────────────────────────

# Microsoft Graph API – Azure App Registration (App-only auth)
# Berechtigungen: Mail.Read (Application) → Admin Consent erforderlich
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=dein-client-secret
# Das freigegebene Postfach, das gelesen werden soll (kein eigenes Postfach)
AZURE_MAILBOX_EMAIL=info@jumax-elektro.de

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Notion Integration
# Integration erstellen unter: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_...
# ID der Tasks-Datenbank (aus Notion URL: notion.so/xxxxxxxx...)
NOTION_TASKS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
